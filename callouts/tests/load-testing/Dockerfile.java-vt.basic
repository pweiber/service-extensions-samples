# Java Virtual Threads (Java 21+) Basic Callout Server
# Uses Executors.newVirtualThreadPerTaskExecutor() for lightweight virtual threads

# Stage 1: Build the Java application using Maven with Java 21
FROM maven:3.9.6-eclipse-temurin-21 AS builder

WORKDIR /app

# Copy pom.xml and download dependencies
COPY service-callout/pom.xml .
RUN mvn dependency:go-offline -B

# Copy source and build
COPY service-callout/src ./src
RUN mvn clean package -DskipTests -B

# Stage 2: Runtime with Java 21 (Eclipse Temurin)
FROM eclipse-temurin:21-jre-jammy

WORKDIR /app

# Copy the built JAR
COPY --from=builder /app/target/service-callout-1.0-SNAPSHOT-jar-with-dependencies.jar app.jar

# Copy SSL certificates
COPY --from=builder /app/src/main/resources/certs ./certs

EXPOSE 80 443 8080

# Create non-root user
RUN groupadd -r appgroup && useradd -r -g appgroup appuser
RUN chown -R appuser:appgroup /app
USER appuser

# Run the Basic callout server example
ENTRYPOINT ["java", "-cp", "app.jar", "example.BasicCalloutServer"]
