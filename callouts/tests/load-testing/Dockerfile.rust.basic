# Rust Basic Callout Server
# Builds the basic (add_header) example

# Stage 1: Build the Rust application
FROM rust:1.82-slim-bullseye AS builder

# Install required dependencies
RUN apt-get update && apt-get install -y \
    curl \
    pkg-config \
    libssl-dev \
    protobuf-compiler \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install buf
RUN curl -sSL \
    "https://github.com/bufbuild/buf/releases/download/v1.29.0/buf-$(uname -s)-$(uname -m)" \
    -o "/usr/local/bin/buf" && \
    chmod +x "/usr/local/bin/buf"

# Set environment variables
ENV RUST_LOG=info

WORKDIR /usr/src/app
COPY . .

# Build the basic example
RUN cargo build --release --example basic

# Stage 2: Create the runtime image
FROM debian:bullseye-slim

# Install necessary dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        libssl1.1 \
    && rm -rf /var/lib/apt/lists/*

ENV RUST_LOG=info
WORKDIR /app

# Copy the built example
COPY --from=builder /usr/src/app/target/release/examples/basic /app/server

# Create the directory structure expected by the server
RUN mkdir -p /app/extproc/ssl_creds

# Copy certificates
COPY --from=builder /usr/src/app/extproc/ssl_creds/* /app/extproc/ssl_creds/

EXPOSE 80 443 8080

# Create non-root user
RUN groupadd -r appgroup && useradd -r -g appgroup appuser
RUN chown -R appuser:appgroup /app
USER appuser

ENTRYPOINT ["/app/server"]
