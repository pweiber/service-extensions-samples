# Java Basic Callout Server (platform threads)
# Simple header manipulation - no CPU-intensive work

# Stage 1: Build the Java application using Maven
FROM maven:3.9.6-eclipse-temurin-17 AS builder

WORKDIR /app

# Copy pom.xml and download dependencies
COPY service-callout/pom.xml .
RUN mvn dependency:go-offline -B

# Copy source and build
COPY service-callout/src ./src
RUN mvn clean package -DskipTests -B

# Stage 2: Runtime with Java 17
FROM eclipse-temurin:17-jre-jammy

WORKDIR /app

# Copy the built JAR
COPY --from=builder /app/target/service-callout-1.0-SNAPSHOT-jar-with-dependencies.jar app.jar

# Copy SSL certificates
COPY --from=builder /app/src/main/resources/certs ./certs

EXPOSE 80 443 8080

# Create non-root user
RUN groupadd -r appgroup && useradd -r -g appgroup appuser
RUN chown -R appuser:appgroup /app
USER appuser

# Run the Basic callout server example
ENTRYPOINT ["java", "-cp", "app.jar", "example.BasicCalloutServer"]
